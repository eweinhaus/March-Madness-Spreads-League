# Copy to .env and fill in. Do not commit .env or .env.production.
# Production secrets belong only in Vercel (or another secret store), not in git.

# --- Firebase Admin (required for Firestore + token verify) ---
# After you create a service account (Firebase Console → Project settings → Service accounts):
# Option A – path to downloaded JSON:
GOOGLE_APPLICATION_CREDENTIALS=

# Option B – entire JSON as one line (typical on Vercel). Omit if using Option A.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- App ---
LEAGUE_ID=march_madness_2025
FRONTEND_URL=http://localhost:5173
PRODUCTION_FRONTEND_URL=

# --- Auto-resolve (CBS scores → cover/push). Set on Vercel + same value in GitHub CRON_SECRET ---
# CRON_SECRET=long-random-string

# --- Optional: local emulators (after: firebase emulators:start) ---
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
